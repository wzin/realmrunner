# Copy this to .env and configure for your setup

# ====== REQUIRED ======

# Your domain for SSL certificate
CADDY_DOMAIN=minecraft.example.com

# Password hash for RealmRunner (generate with ./generate-password.sh)
REALMRUNNER_PASSWORD_HASH=$$2b$$12$$YourHashHere

# ====== SSL MODE ======

# Option 1: Let's Encrypt (default - leave these empty)
CADDY_TLS_CERT=
CADDY_TLS_KEY=

# Option 2: Custom certificates
# Set paths relative to /etc/caddy/certs/ inside container
# CADDY_TLS_CERT=/etc/caddy/certs/cert.pem
# CADDY_TLS_KEY=/etc/caddy/certs/privkey.pem

# ====== OPTIONAL CONFIGURATION ======

# RealmRunner image (use ghcr.io/wzin/realmrunner:main or build locally)
REALMRUNNER_IMAGE=ghcr.io/wzin/realmrunner:main

# Server settings
REALMRUNNER_MAX_RUNNING=3
REALMRUNNER_MEMORY_MB=2048
REALMRUNNER_JWT_SECRET=change-me-in-production

# Port configuration
MINECRAFT_PORT_RANGE=25565-25600
HTTP_PORT=80
HTTPS_PORT=443

# Data directories (relative or absolute paths)
DATA_DIR=./data
CADDY_DATA_DIR=./caddy_data
CADDY_CONFIG_DIR=./caddy_config
CERTS_DIR=./certs